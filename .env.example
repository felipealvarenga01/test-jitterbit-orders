MONGODB_URI=mongodb+srv://<seu_usuario>:<suasenha>@<seu_cluster>/desafio_orders
PORT=3000
# Em produção (ex.: Render), defina a URL pública da API para o Swagger/curl usar (ex.: https://sua-api.onrender.com)
# BASE_URL=https://test-jitterbit-orders.onrender.com
LOG_LEVEL=debug

# JWT (use um segredo forte em produção: openssl rand -base64 32)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Credenciais do admin criado pelo seed (npm run seed)
AUTH_USER=admin
AUTH_PASSWORD=admin
